# Environment variables for Telegram notification script
# Copy this file to .env and fill in your actual values

# Required: Telegram Bot credentials
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_THREAD_ID=your_thread_id_here  # Optional, remove if not using topics

# Required: Telegram API credentials (get from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Optional: GitHub repository and token
GITHUB_REPOSITORY=sang765/ArchiveTune-Nightly
GITHUB_TOKEN=your_github_pat_here
